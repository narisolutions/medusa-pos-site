  },
  {
    title: 'Cash Drawer',
    description: 'Automatic cash drawer trigger on completed payments.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="m20.25 7.5-.625 10.632a2.25 2.25 0 0 1-2.247 2.118H6.622a2.25 2.25 0 0 1-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125Z"/>`,
  },
  {
    title: 'Order Management',
    description: 'Order list, detail views, status tracking, and fulfillment workflows.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15a2.25 2.25 0 0 1 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V19.5a2.25 2.25 0 0 0 2.25 2.25h.75"/>`,
  },
  {
    title: 'Shipping',
    description: 'Shipping labels and pickup confirmation for fulfilled orders.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0H21M3.375 14.25h3.038c.26 0 .515-.058.75-.168M3.375 14.25A1.125 1.125 0 0 0 2.25 15.375V16.5m14.77-2.418a4.5 4.5 0 0 0-.946-1.06l-2.042-1.737A4.5 4.5 0 0 0 11.1 10.1H8.25m8.77 3.65a4.5 4.5 0 0 1 .946 1.06M20.25 15.375V16.5a1.125 1.125 0 0 1-1.125 1.125h-.375"/>`,
  },
  {
    title: 'Multi-Store',
    description: 'Configure multiple backend connections with per-store settings.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 .75.75V21m-4.5 0H2.36a1.06 1.06 0 0 1-1.06-1.06v-9.19a1.06 1.06 0 0 1 .353-.79l9.14-8.28a1.06 1.06 0 0 1 1.414 0l9.14 8.28a1.06 1.06 0 0 1 .354.79v9.19A1.06 1.06 0 0 1 21.64 21H13.5"/>`,
  },
  {
    title: 'Localization',
    description: 'Built-in support for multiple locales, currencies, and languages across the entire interface.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="m10.5 21 5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 0 1 6-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.785.147 2.666.257m-4.589 8.495a18.023 18.023 0 0 1-3.827-5.802"/>`,
  },
  {
    title: 'Auto-Updates',
    description: 'Built-in updater checks GitHub Releases and installs updates with one click.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182"/>`,
  },
];
---

<section id="features" class="mx-auto max-w-6xl px-6 py-20">
  <h2 class="text-center text-3xl font-bold md:text-4xl">Features</h2>
  <p class="mx-auto mt-4 max-w-2xl text-center text-[var(--color-text-secondary)]">
    Everything you need to run a point-of-sale workflow on top of MedusaJS.
  </p>

  <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {features.map((f) => (
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 transition-colors hover:border-[var(--color-accent)]/40">
        <svg class="h-6 w-6 text-[var(--color-accent)]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <Fragment set:html={f.icon} />
        </svg>
        <h3 class="mt-4 text-lg font-semibold">{f.title}</h3>
        <p class="mt-2 text-sm text-[var(--color-text-secondary)]">{f.description}</p>
      </div>
    ))}
  </div>
</section>
