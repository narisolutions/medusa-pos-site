---
const base = import.meta.env.BASE_URL;
---

<header class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-bg)]/95 backdrop-blur-sm">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href={base} class="flex items-center gap-3">
      <img src={`${base}logo.svg`} alt="Medusa POS" class="h-8 w-8" />
      <span class="text-lg font-semibold">Medusa POS</span>
    </a>
    <div class="flex items-center gap-6 text-sm text-[var(--color-text-secondary)]">
      <a href="#features" class="transition-colors hover:text-[var(--color-text-primary)]">Features</a>
      <a href="#downloads" class="transition-colors hover:text-[var(--color-text-primary)]">Downloads</a>
      <a
        href="https://github.com/narisolutions/medusa-pos"
        target="_blank"
        rel="noopener noreferrer"
        class="transition-colors hover:text-[var(--color-text-primary)]"
      >
        GitHub
        <svg class="ml-1 inline-block h-3 w-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14 21 3" />
        </svg>
      </a>
    </div>
  </nav>
</header>
