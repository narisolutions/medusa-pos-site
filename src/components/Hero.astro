---
const base = import.meta.env.BASE_URL;
const darkShots = [1, 2, 3, 4, 5].map(n => ({ src: `${base}screenshots/dark${n}.png`, alt: `Medusa POS dark screenshot ${n}` }));
const lightShots = [1, 2, 3, 4, 5].map(n => ({ src: `${base}screenshots/light${n}.png`, alt: `Medusa POS light screenshot ${n}` }));
---

<section class="mx-auto max-w-6xl px-6 py-24 text-center md:py-32">
  <h1 class="text-4xl font-bold tracking-tight md:text-5xl lg:text-6xl">
    Point of Sale for
    <span class="text-[var(--color-accent)]">MedusaJS</span>
  </h1>
  <p class="mx-auto mt-6 max-w-2xl text-lg text-[var(--color-text-secondary)] md:text-xl">
    A cross-platform desktop app for checkout, orders, receipts, and more — powered by Medusa's Admin API.
  </p>
  <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
    <a
      href="#downloads"
      class="rounded-lg bg-[var(--color-accent)] px-6 py-3 font-medium text-white transition-colors hover:bg-[var(--color-accent-hover)]"
    >
      Download
    </a>
    <a
      href="https://github.com/narisolutions/medusa-pos"
      target="_blank"
      rel="noopener noreferrer"
      class="rounded-lg border border-[var(--color-border)] px-6 py-3 font-medium text-[var(--color-text-primary)] transition-colors hover:border-[var(--color-text-secondary)]"
    >
      View on GitHub
    </a>
  </div>

  <!-- Screenshot sliders -->
  <div class="mx-auto mt-16 max-w-4xl">

    <!-- Dark slider -->
    <div data-theme-view="dark" data-slider class="slider-root rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]">
      <div data-slider-viewport class="slider-viewport">
        <div data-slider-track class="slider-track">
          {darkShots.map(s => (
            <div data-slide class="slider-slide">
              <img src={s.src} alt={s.alt} class="slider-img" draggable="false" />
            </div>
          ))}
        </div>
        <button data-slider-prev class="slider-btn slider-btn--prev" aria-label="Previous screenshot">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
        </button>
        <button data-slider-next class="slider-btn slider-btn--next" aria-label="Next screenshot">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </button>
      </div>
      <div class="slider-dots">
        {darkShots.map((_, i) => (
          <button data-dot class:list={['slider-dot', { 'is-active': i === 0 }]} aria-label={`Go to screenshot ${i + 1}`}></button>
        ))}
      </div>
    </div>

    <!-- Light slider -->
    <div data-theme-view="light" data-slider class="slider-root rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]">
      <div data-slider-viewport class="slider-viewport">
        <div data-slider-track class="slider-track">
          {lightShots.map(s => (
            <div data-slide class="slider-slide">
              <img src={s.src} alt={s.alt} class="slider-img" draggable="false" />
            </div>
          ))}
        </div>
        <button data-slider-prev class="slider-btn slider-btn--prev" aria-label="Previous screenshot">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
        </button>
        <button data-slider-next class="slider-btn slider-btn--next" aria-label="Next screenshot">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </button>
      </div>
      <div class="slider-dots">
        {lightShots.map((_, i) => (
          <button data-dot class:list={['slider-dot', { 'is-active': i === 0 }]} aria-label={`Go to screenshot ${i + 1}`}></button>
        ))}
      </div>
    </div>

  </div>

  <!-- Lightbox (shared, always in DOM) -->
  <div id="lightbox" class="lightbox is-hidden" role="dialog" aria-modal="true" aria-label="Screenshot viewer">
    <div class="lightbox-backdrop" id="lightbox-backdrop"></div>
    <button id="lightbox-close" class="lightbox-close" aria-label="Close">
      <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M18 6L6 18M6 6l12 12" />
      </svg>
    </button>
    <div class="lightbox-inner">
      <button id="lightbox-prev" class="lightbox-nav" aria-label="Previous screenshot">
        <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
      <img id="lightbox-img" src="" alt="" class="lightbox-img" draggable="false" />
      <button id="lightbox-next" class="lightbox-nav" aria-label="Next screenshot">
        <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </div>
    <p id="lightbox-counter" class="lightbox-counter"></p>
  </div>
</section>

<style is:global>
  /* ── Slider ─────────────────────────────────────── */
  .slider-root { position: relative; }

  .slider-viewport {
    position: relative;
    overflow: hidden;
  }

  .slider-track {
    display: flex;
    transition: transform 320ms ease;
    will-change: transform;
  }

  .slider-slide {
    flex: 0 0 100%;
    min-width: 0;
  }

  .slider-img {
    width: 100%;
    height: auto;
    display: block;
    cursor: zoom-in;
    user-select: none;
    -webkit-user-drag: none;
  }

  .slider-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.45);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 150ms;
    z-index: 1;
  }
  .slider-btn:hover { background: rgba(0, 0, 0, 0.72); }
  .slider-btn--prev { left: 12px; }
  .slider-btn--next { right: 12px; }

  .slider-dots {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    padding: 14px;
  }

  .slider-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-border);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background 150ms, transform 150ms;
  }

  .slider-dot.is-active {
    background: var(--color-accent);
    transform: scale(1.45);
  }

  /* ── Lightbox ────────────────────────────────────── */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .lightbox.is-hidden { display: none; }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.88);
    cursor: pointer;
  }

  .lightbox-close {
    position: absolute;
    top: 16px;
    right: 16px;
    z-index: 1;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 150ms;
  }
  .lightbox-close:hover { background: rgba(255, 255, 255, 0.22); }

  .lightbox-inner {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .lightbox-img {
    max-width: calc(100vw - 160px);
    max-height: calc(100vh - 96px);
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 8px;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.6);
    display: block;
  }

  .lightbox-nav {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 150ms;
  }
  .lightbox-nav:hover { background: rgba(255, 255, 255, 0.22); }

  .lightbox-counter {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
    color: rgba(255, 255, 255, 0.6);
    font-size: 13px;
    letter-spacing: 0.05em;
    pointer-events: none;
  }
</style>

<script is:inline>
  (function () {
    // ── Sliders ──────────────────────────────────────
    document.querySelectorAll('[data-slider]').forEach(function (sliderEl) {
      var viewport = sliderEl.querySelector('[data-slider-viewport]');
      var track    = sliderEl.querySelector('[data-slider-track]');
      var slides   = Array.from(sliderEl.querySelectorAll('[data-slide]'));
      var dots     = Array.from(sliderEl.querySelectorAll('[data-dot]'));
      var prevBtn  = sliderEl.querySelector('[data-slider-prev]');
      var nextBtn  = sliderEl.querySelector('[data-slider-next]');
      var total    = slides.length;
      var current  = 0;

      function goTo(index) {
        current = ((index % total) + total) % total;
        track.style.transform = 'translateX(-' + (current * viewport.offsetWidth) + 'px)';
        dots.forEach(function (d, i) { d.classList.toggle('is-active', i === current); });
      }

      if (prevBtn) prevBtn.addEventListener('click', function (e) { e.stopPropagation(); goTo(current - 1); });
      if (nextBtn) nextBtn.addEventListener('click', function (e) { e.stopPropagation(); goTo(current + 1); });
      dots.forEach(function (d, i) { d.addEventListener('click', function () { goTo(i); }); });

      // Touch swipe
      var touchStartX = 0;
      track.addEventListener('touchstart', function (e) { touchStartX = e.touches[0].clientX; }, { passive: true });
      track.addEventListener('touchend', function (e) {
        var delta = touchStartX - e.changedTouches[0].clientX;
        if (Math.abs(delta) > 50) goTo(delta > 0 ? current + 1 : current - 1);
      });

      // Recalculate position on resize so slides don't get misaligned
      window.addEventListener('resize', function () {
        track.style.transition = 'none';
        track.style.transform = 'translateX(-' + (current * viewport.offsetWidth) + 'px)';
        requestAnimationFrame(function () { track.style.transition = ''; });
      });
    });

    // ── Lightbox ─────────────────────────────────────
    var lightbox        = document.getElementById('lightbox');
    var lightboxImg     = document.getElementById('lightbox-img');
    var lightboxCounter = document.getElementById('lightbox-counter');
    var lightboxClose   = document.getElementById('lightbox-close');
    var lightboxPrev    = document.getElementById('lightbox-prev');
    var lightboxNext    = document.getElementById('lightbox-next');
    var lightboxBackdrop = document.getElementById('lightbox-backdrop');

    var lbImages = [];
    var lbIndex  = 0;

    function openLightbox(images, index) {
      lbImages = images;
      lbIndex  = index;
      updateLightbox();
      lightbox.classList.remove('is-hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      lightbox.classList.add('is-hidden');
      document.body.style.overflow = '';
    }

    function updateLightbox() {
      lightboxImg.src = lbImages[lbIndex].src;
      lightboxImg.alt = lbImages[lbIndex].alt;
      lightboxCounter.textContent = (lbIndex + 1) + ' / ' + lbImages.length;
    }

    function lbNav(dir) {
      lbIndex = ((lbIndex + dir) % lbImages.length + lbImages.length) % lbImages.length;
      updateLightbox();
    }

    // Open lightbox when a slide image is clicked
    document.querySelectorAll('[data-slide] img').forEach(function (img) {
      img.addEventListener('click', function () {
        var slider = img.closest('[data-slider]');
        var imgs   = Array.from(slider.querySelectorAll('[data-slide] img'));
        openLightbox(imgs, imgs.indexOf(img));
      });
    });

    if (lightboxClose)   lightboxClose.addEventListener('click', closeLightbox);
    if (lightboxBackdrop) lightboxBackdrop.addEventListener('click', closeLightbox);
    if (lightboxPrev)    lightboxPrev.addEventListener('click', function () { lbNav(-1); });
    if (lightboxNext)    lightboxNext.addEventListener('click', function () { lbNav(1); });

    document.addEventListener('keydown', function (e) {
      if (!lightbox || lightbox.classList.contains('is-hidden')) return;
      if (e.key === 'Escape')      closeLightbox();
      else if (e.key === 'ArrowLeft')  lbNav(-1);
      else if (e.key === 'ArrowRight') lbNav(1);
    });
  })();
</script>
