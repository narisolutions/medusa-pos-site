---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Downloads from '../components/Downloads.astro';
import Compatibility from '../components/Compatibility.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<Layout
  title="Medusa POS — Point of Sale for MedusaJS"
  description="Cross-platform desktop POS app for MedusaJS. Checkout, orders, receipt printing, and more. Built with React and Tauri."
>
  <Header />
  <main>
    <Hero />
    <Features />
    <Downloads />
    <Compatibility />
  </main>
  <Footer />
</Layout>
