---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';

const base = import.meta.env.BASE_URL;

const articles = [
  {
    title: 'Introducing Medusa POS',
    description:
      'Why we built Medusa POS, who it is for, and what retailers can expect from an open-source desktop checkout app.',
    href: `${base}blog/introducing-medusa-pos`,
    publishedAt: '2026-03-24',
    publishedLabel: 'Mar 24, 2026',
  },
  {
    title: 'Getting Started with Medusa POS',
    description:
      'A practical setup guide: install, connect your Medusa backend, configure printers, and run your first checkout flow.',
    href: `${base}blog/getting-started-with-medusa-pos`,
    publishedAt: '2026-03-24',
    publishedLabel: 'Mar 24, 2026',
  },
];
---

<Layout
  title="Medusa POS Blog"
  description="Read Medusa POS articles, including product introduction and a step-by-step getting started guide."
>
  <Header variant="blog" />

  <main>
    <section class="mx-auto max-w-3xl px-6 py-11">
      <a
        href={base}
        class="mb-8 inline-flex items-center gap-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-2 text-sm text-[var(--color-text-primary)] transition-colors hover:border-[var(--color-text-secondary)]"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Back to home page
      </a>
      <h1 class="text-3xl font-semibold tracking-tight text-[var(--color-text-primary)]">
        Medusa POS Blog
      </h1>
      <p class="mt-4 text-[var(--color-text-secondary)]">
        Product updates, practical guides, and setup tutorials for running Medusa POS in real stores.
      </p>

      <div class="mt-8 space-y-4">
        {articles.map((article) => (
          <article class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6">
            <h2 class="text-xl font-semibold text-[var(--color-text-primary)]">
              <a href={article.href} class="hover:underline">
                {article.title}
              </a>
            </h2>
            <p class="mt-2 text-sm text-[var(--color-text-secondary)]">
              <time datetime={article.publishedAt}>Published {article.publishedLabel}</time>
            </p>
            <p class="mt-3 text-[var(--color-text-secondary)]">{article.description}</p>
            <a
              href={article.href}
              class="mt-5 inline-flex items-center gap-2 font-medium text-[var(--color-accent)] hover:text-[var(--color-accent-hover)]"
            >
              Read article
              <span aria-hidden="true">→</span>
            </a>
          </article>
        ))}
      </div>
    </section>
  </main>

  <Footer compact />
</Layout>
